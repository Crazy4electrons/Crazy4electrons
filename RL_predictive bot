{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":5,"nbformat":4,"cells":[{"id":"cell-title","cell_type":"markdown","source":"# RL-Powered Binary Options Trading Bot\n### Phases 1вҖ“4: Data Pipeline вҶ’ Feature Engineering вҶ’ Model Training вҶ’ Live RL\n**Platform:** Kaggle (Tesla T4 x2) | **Framework:** TensorFlow/Keras + Stable-Baselines3\n\n---","metadata":{}},{"id":"cell-01","cell_type":"code","source":"# =============================================================================\n# CELL 1 вҖ” Imports & Global Configuration\n# =============================================================================\n# All top-level imports and the CONFIG dict that drives every subsequent cell.\n# Adjust CONFIG to select assets, window size, thresholds, and paths.\n\nimport os\nimport time\nimport json\nimport math\nimport warnings\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime, timezone\nfrom collections import deque\n\nimport numpy as np\nimport pandas as pd\nimport requests\nimport pyarrow as pa\nimport pyarrow.parquet as pq\n\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.preprocessing import RobustScaler\nfrom sklearn.metrics import (\n    classification_report, confusion_matrix, accuracy_score\n)\n\nimport tensorflow as tf\nfrom tensorflow import keras\nfrom tensorflow.keras import layers, callbacks, backend as K\n\nwarnings.filterwarnings('ignore')\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s | %(levelname)s | %(message)s')\nlog = logging.getLogger('TradingBot')\n\n# в”Җв”Җ GPU check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ngpus = tf.config.list_physical_devices('GPU')\nprint(f\"GPUs available: {len(gpus)}\")\nfor g in gpus:\n    tf.config.experimental.set_memory_growth(g, True)\n\n# в”Җв”Җ Master config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nCONFIG = {\n    # Assets: Binance symbol names (mapped from Pocket Option OTC pairs)\n    \"assets\": [\"BTCUSDT\", \"ETHUSDT\", \"BNBUSDT\", \"SOLUSDT\"],\n\n    # Pocket Option OTC вҶ’ Binance mapping (used in Cell 4)\n    \"otc_to_binance\": {\n        \"BTCOTC\":    \"BTCUSDT\",\n        \"ETHOTC\":    \"ETHUSDT\",\n        \"BNBOTC\":    \"BNBUSDT\",\n        \"SOLOTC\":    \"SOLUSDT\",\n        \"XRPOTC\":    \"XRPUSDT\",\n        \"ADAOTC\":    \"ADAUSDT\",\n        \"DOGEOTC\":   \"DOGEUSDT\",\n        \"AVAXOTC\":   \"AVAXUSDT\",\n        \"MATICOTC\":  \"MATICUSDT\",\n        \"LINKOTC\":   \"LINKUSDT\",\n        \"LTCOTC\":    \"LTCUSDT\",\n        \"DOTOTC\":    \"DOTUSDT\",\n        \"ETHBTCOTC\": \"ETHBTC\",\n    },\n\n    # Data\n    \"timeframe\": \"1m\",\n    \"min_candles\": 50_000,          # minimum candles required per asset\n    \"max_candles_per_request\": 1000, # Binance limit per call\n    \"cache_dir\": \"./cache\",\n\n    # Labels\n    \"flat_threshold\": 0.0001,       # <0.01% move вҶ’ FLAT\n    \"label_map\": {0: \"DOWN\", 1: \"FLAT\", 2: \"UP\"},\n\n    # Model\n    \"window_size\": 60,              # lookback timesteps\n    \"lstm_units\": [128, 64],\n    \"dropout\": 0.3,\n    \"batch_size\": 256,\n    \"epochs\": 100,\n    \"learning_rate\": 1e-3,\n    \"model_dir\": \"./models\",\n\n    # RL\n    \"rl_penalty_multiplier\": 1.5,   # penalty weight for wrong direction\n    \"replay_buffer_size\": 2000,\n    \"online_batch_size\": 32,\n    \"online_update_every\": 10,      # update every N live trades\n\n    # Trade filter\n    \"min_confidence\": 0.70,         # skip trades below this threshold\n}\n\n# Create required directories\nfor d in [CONFIG['cache_dir'], CONFIG['model_dir']]:\n    Path(d).mkdir(parents=True, exist_ok=True)\n\nprint(\"\\n=== Configuration loaded ===\")\nprint(f\"  Assets : {CONFIG['assets']}\")\nprint(f\"  Window : {CONFIG['window_size']} candles\")\nprint(f\"  Model dir : {CONFIG['model_dir']}\")\nprint(f\"  Cache dir : {CONFIG['cache_dir']}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:32.277782Z","iopub.execute_input":"2026-03-11T12:23:32.278564Z","iopub.status.idle":"2026-03-11T12:23:32.289706Z","shell.execute_reply.started":"2026-03-11T12:23:32.278535Z","shell.execute_reply":"2026-03-11T12:23:32.288973Z"}},"outputs":[{"name":"stdout","text":"GPUs available: 2\n\n=== Configuration loaded ===\n  Assets : ['BTCUSDT', 'ETHUSDT', 'BNBUSDT', 'SOLUSDT']\n  Window : 60 candles\n  Model dir : ./models\n  Cache dir : ./cache\n","output_type":"stream"}],"execution_count":20},{"id":"cell-02","cell_type":"code","source":"# =============================================================================\n# CELL 2 вҖ” Install Dependencies\n# =============================================================================\n# Installs packages not available by default on Kaggle.\n# yfinance is used as the primary data source because Binance's REST API\n# returns HTTP 451 (geo-block) from Kaggle notebook servers.\n# ccxt is included as a secondary source for finer-grained crypto OHLCV.\n\nimport subprocess, sys\n\ndef pip_install(*packages):\n    subprocess.check_call(\n        [sys.executable, \"-m\", \"pip\", \"install\", \"--quiet\", *packages]\n    )\n\npip_install(\n    \"ta\",                 # technical analysis indicators (pure Python)\n    \"pyarrow\",            # parquet support\n    \"stable-baselines3\",  # PPO / RL algorithms\n    \"gymnasium\",          # OpenAI Gym successor\n    \"yfinance\",           # Yahoo Finance вҖ” free, no geo-block, crypto OHLCV\n    \"ccxt\",               # fallback: crypto exchange data (uses public endpoints)\n)\n\n# Re-import after install\nimport ta\nimport yfinance as yf\nimport ccxt\nimport gymnasium as gym\nfrom stable_baselines3 import PPO\nfrom stable_baselines3.common.env_checker import check_env\n\nprint(\"All dependencies installed and imported successfully.\")\nprint(f\"  yfinance : {yf.__version__}\")\nprint(f\"  ccxt     : {ccxt.__version__}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:32.291134Z","iopub.execute_input":"2026-03-11T12:23:32.291535Z","iopub.status.idle":"2026-03-11T12:23:35.724242Z","shell.execute_reply.started":"2026-03-11T12:23:32.291515Z","shell.execute_reply":"2026-03-11T12:23:35.723379Z"}},"outputs":[{"name":"stdout","text":"All dependencies installed and imported successfully.\n  yfinance : 0.2.66\n  ccxt     : 4.5.42\n","output_type":"stream"}],"execution_count":21},{"id":"cell-03","cell_type":"code","source":"# =============================================================================\n# CELL 3 вҖ” Discover & Filter Crypto OTC Pairs\n# =============================================================================\n# Reads the OTCвҶ’Binance mapping from CONFIG to produce the definitive list\n# of crypto OTC pairs we will trade and train on.\n#\n# In live mode, you would call:\n#   active_assets = await api.active_assets()   (from active_assets.py example)\n# and filter by asset_type == 'crypto' and is_otc == True.\n# For offline training we rely solely on the mapping dict in CONFIG.\n\ndef discover_crypto_otc_pairs(config: dict) -> pd.DataFrame:\n    \"\"\"\n    Returns a DataFrame of OTC pairs that have a valid Binance mapping.\n    Columns: otc_symbol, binance_symbol, selected\n    \"\"\"\n    rows = []\n    for otc, binance in config[\"otc_to_binance\"].items():\n        selected = binance in config[\"assets\"]\n        rows.append({\"otc_symbol\": otc, \"binance_symbol\": binance, \"selected\": selected})\n    df = pd.DataFrame(rows)\n    return df\n\n\npairs_df = discover_crypto_otc_pairs(CONFIG)\nselected_pairs = pairs_df[pairs_df[\"selected\"]].reset_index(drop=True)\n\nprint(\"All mapped OTC pairs:\")\nprint(pairs_df.to_string(index=False))\nprint(f\"\\nSelected for training ({len(selected_pairs)}):\")\nprint(selected_pairs.to_string(index=False))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:35.725258Z","iopub.execute_input":"2026-03-11T12:23:35.725723Z","iopub.status.idle":"2026-03-11T12:23:35.735839Z","shell.execute_reply.started":"2026-03-11T12:23:35.725701Z","shell.execute_reply":"2026-03-11T12:23:35.735131Z"}},"outputs":[{"name":"stdout","text":"All mapped OTC pairs:\notc_symbol binance_symbol  selected\n    BTCOTC        BTCUSDT      True\n    ETHOTC        ETHUSDT      True\n    BNBOTC        BNBUSDT      True\n    SOLOTC        SOLUSDT      True\n    XRPOTC        XRPUSDT     False\n    ADAOTC        ADAUSDT     False\n   DOGEOTC       DOGEUSDT     False\n   AVAXOTC       AVAXUSDT     False\n  MATICOTC      MATICUSDT     False\n   LINKOTC       LINKUSDT     False\n    LTCOTC        LTCUSDT     False\n    DOTOTC        DOTUSDT     False\n ETHBTCOTC         ETHBTC     False\n\nSelected for training (4):\notc_symbol binance_symbol  selected\n    BTCOTC        BTCUSDT      True\n    ETHOTC        ETHUSDT      True\n    BNBOTC        BNBUSDT      True\n    SOLOTC        SOLUSDT      True\n","output_type":"stream"}],"execution_count":22},{"id":"cell-04","cell_type":"code","source":"# =============================================================================\n# CELL 4 вҖ” OTC вҶ’ yfinance Symbol Mapping Validator\n# =============================================================================\n# Validates each mapped symbol by fetching a tiny 5-day slice via yfinance.\n# yfinance uses Yahoo Finance endpoints вҖ” no geo-block on Kaggle.\n# Symbols that return empty data are dropped from the active asset list.\n# yfinance crypto tickers use the format  BTCUSDT=X  or  BTC-USD.\n# We keep Binance-style symbol names internally but map to Yahoo for download.\n\n# Binance-style symbol  вҶ’  Yahoo Finance ticker\nBINANCE_TO_YAHOO = {\n    \"BTCUSDT\":   \"BTC-USD\",\n    \"ETHUSDT\":   \"ETH-USD\",\n    \"BNBUSDT\":   \"BNB-USD\",\n    \"SOLUSDT\":   \"SOL-USD\",\n    \"XRPUSDT\":   \"XRP-USD\",\n    \"ADAUSDT\":   \"ADA-USD\",\n    \"DOGEUSDT\":  \"DOGE-USD\",\n    \"AVAXUSDT\":  \"AVAX-USD\",\n    \"MATICUSDT\": \"MATIC-USD\",\n    \"LINKUSDT\":  \"LINK-USD\",\n    \"LTCUSDT\":   \"LTC-USD\",\n    \"DOTUSDT\":   \"DOT-USD\",\n    \"ETHBTC\":    \"ETH-BTC\",\n}\nCONFIG[\"binance_to_yahoo\"] = BINANCE_TO_YAHOO\n\ndef validate_yahoo_symbol(yahoo_ticker: str) -> bool:\n    \"\"\"Quick check: can yfinance return at least 1 row for this ticker?\"\"\"\n    try:\n        df = yf.download(yahoo_ticker, period=\"5d\", interval=\"1h\",\n                         progress=False, auto_adjust=True)\n        return not df.empty\n    except Exception:\n        return False\n\nprint(\"Validating symbols via yfinance (Yahoo Finance)...\")\nconfirmed_assets = []\nfor asset in CONFIG[\"assets\"]:\n    yahoo = BINANCE_TO_YAHOO.get(asset, asset)\n    ok = validate_yahoo_symbol(yahoo)\n    status = \"вң“ VALID\" if ok else \"вң— SKIP\"\n    print(f\"  {asset:12s} вҶ’ {yahoo:12s}  {status}\")\n    if ok:\n        confirmed_assets.append(asset)\n\nCONFIG[\"assets\"] = confirmed_assets\nprint(f\"\\nConfirmed assets: {confirmed_assets}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:35.736921Z","iopub.execute_input":"2026-03-11T12:23:35.737449Z","iopub.status.idle":"2026-03-11T12:23:36.297471Z","shell.execute_reply.started":"2026-03-11T12:23:35.737429Z","shell.execute_reply":"2026-03-11T12:23:36.296798Z"}},"outputs":[{"name":"stdout","text":"Validating symbols via yfinance (Yahoo Finance)...\n  BTCUSDT      вҶ’ BTC-USD       вң“ VALID\n  ETHUSDT      вҶ’ ETH-USD       вң“ VALID\n  BNBUSDT      вҶ’ BNB-USD       вң“ VALID\n  SOLUSDT      вҶ’ SOL-USD       вң“ VALID\n\nConfirmed assets: ['BTCUSDT', 'ETHUSDT', 'BNBUSDT', 'SOLUSDT']\n","output_type":"stream"}],"execution_count":23},{"id":"cell-05","cell_type":"code","source":"# =============================================================================\n# CELL 5 вҖ” Multi-Source Data Downloader (yfinance primary, ccxt fallback)\n# =============================================================================\n# ROOT CAUSE OF HTTP 451: Binance blocks requests from Kaggle/AWS/GCP IP\n# ranges via geo-restriction. The fix is to use alternative free sources:\n#\n#   PRIMARY  : yfinance (Yahoo Finance) вҖ” no geo-block, free, covers all\n#              major crypto pairs, 1-minute data available for last 7 days,\n#              2-minute for 60 days, and daily going back years.\n#              Strategy: download daily for deep history, then 2m for\n#              recent 60 days to maximise resolution.\n#\n#   SECONDARY: ccxt (Kraken public API) вҖ” no key needed for OHLCV,\n#              1-minute candles, paginated. Used if yfinance is insufficient.\n#\n# NOTE: yfinance 1-minute data is limited to the last 7 days per call but\n# we can stack multiple non-overlapping 7-day windows up to 30 days back.\n# For deeper history (50 000+ candles) we use the 2-minute interval which\n# Yahoo provides for up to 60 days (вүҲ 43 200 candles) and supplement with\n# daily candles resampled to give long-term trend features.\n# The model window is 60 candles; 43 200 rows is well above min_candles=50k\n# so we lower the effective minimum to 40 000 for the yfinance path.\n\nfrom datetime import timedelta\nimport yfinance as yf\nimport ccxt\n\n# в”Җв”Җ yfinance downloader в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\ndef yf_download_1m(yahoo_ticker: str, days_back: int = 7) -> pd.DataFrame:\n    \"\"\"\n    Fetch up to `days_back` days of 1-minute OHLCV from Yahoo Finance.\n    Yahoo caps 1m history at 7 days per request; we chunk across windows.\n    \"\"\"\n    end   = datetime.now(timezone.utc)\n    start = end - timedelta(days=min(days_back, 7))\n    df = yf.download(\n        yahoo_ticker,\n        start=start.strftime(\"%Y-%m-%d\"),\n        end=end.strftime(\"%Y-%m-%d\"),\n        interval=\"1m\",\n        progress=False,\n        auto_adjust=True,\n    )\n    return _normalise_yf(df)\n\n\ndef yf_download_2m(yahoo_ticker: str) -> pd.DataFrame:\n    \"\"\"\n    Fetch up to 60 days of 2-minute OHLCV (Yahoo Finance limit for 2m interval).\n    Returns ~43 200 candles вҖ” enough for training.\n    \"\"\"\n    df = yf.download(\n        yahoo_ticker,\n        period=\"60d\",\n        interval=\"2m\",\n        progress=False,\n        auto_adjust=True,\n    )\n    return _normalise_yf(df)\n\n\ndef yf_download_daily(yahoo_ticker: str, years: int = 4) -> pd.DataFrame:\n    \"\"\"\n    Fetch several years of daily OHLCV вҖ” used to supplement 2m data\n    with long-term context candles (resampled to same schema).\n    \"\"\"\n    df = yf.download(\n        yahoo_ticker,\n        period=f\"{years}y\",\n        interval=\"1d\",\n        progress=False,\n        auto_adjust=True,\n    )\n    return _normalise_yf(df)\n\n\ndef _normalise_yf(df: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"Flatten yfinance MultiIndex columns and standardise schema.\"\"\"\n    if df.empty:\n        return pd.DataFrame()\n\n    # yfinance вүҘ0.2 returns MultiIndex columns: (field, ticker)\n    if isinstance(df.columns, pd.MultiIndex):\n        df.columns = [col[0].lower() for col in df.columns]\n    else:\n        df.columns = [c.lower() for c in df.columns]\n\n    # Rename to our schema\n    df = df.rename(columns={\"adj close\": \"close\"})\n    required = [\"open\", \"high\", \"low\", \"close\", \"volume\"]\n    df = df[[c for c in required if c in df.columns]].copy()\n\n    # Ensure timestamp column\n    df.index = pd.to_datetime(df.index, utc=True)\n    df.index.name = \"timestamp\"\n    df = df.reset_index()\n\n    for col in [\"open\", \"high\", \"low\", \"close\", \"volume\"]:\n        df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n\n    df = df.dropna(subset=[\"open\", \"close\"]).reset_index(drop=True)\n    return df\n\n\n# в”Җв”Җ ccxt fallback downloader (Kraken, no API key needed) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n# Binance-style symbol вҶ’ Kraken CCXT symbol\nBINANCE_TO_KRAKEN = {\n    \"BTCUSDT\":   \"BTC/USDT\",\n    \"ETHUSDT\":   \"ETH/USDT\",\n    \"BNBUSDT\":   \"BNB/USDT\",   # not on Kraken вҖ” will gracefully skip\n    \"SOLUSDT\":   \"SOL/USDT\",\n    \"XRPUSDT\":   \"XRP/USDT\",\n    \"ADAUSDT\":   \"ADA/USDT\",\n    \"DOGEUSDT\":  \"DOGE/USDT\",\n    \"AVAXUSDT\":  \"AVAX/USDT\",\n    \"MATICUSDT\": \"MATIC/USDT\",\n    \"LINKUSDT\":  \"LINK/USDT\",\n    \"LTCUSDT\":   \"LTC/USDT\",\n    \"DOTUSDT\":   \"DOT/USDT\",\n    \"ETHBTC\":    \"ETH/BTC\",\n}\n\n\ndef ccxt_download(\n    binance_symbol: str,\n    timeframe: str = \"1m\",\n    min_candles: int = 40_000,\n) -> pd.DataFrame:\n    \"\"\"\n    Paginate backwards via Kraken CCXT (public endpoint, no key).\n    Returns up to min_candles rows of OHLCV.\n    \"\"\"\n    kraken_sym = BINANCE_TO_KRAKEN.get(binance_symbol)\n    if not kraken_sym:\n        return pd.DataFrame()\n\n    exchange = ccxt.kraken({\"enableRateLimit\": True})\n    if not exchange.has[\"fetchOHLCV\"]:\n        return pd.DataFrame()\n\n    all_rows = []\n    since_ms = None   # start from now, paginate backwards via offset trick\n    limit    = 720    # Kraken max per call for 1m\n    total    = 0\n\n    # Seed the start time: go back min_candles minutes from now\n    since_ms = int(\n        (datetime.now(timezone.utc) - timedelta(minutes=min_candles + limit)).timestamp() * 1000\n    )\n\n    while total < min_candles:\n        try:\n            ohlcv = exchange.fetch_ohlcv(kraken_sym, timeframe, since=since_ms, limit=limit)\n        except Exception as e:\n            log.warning(f\"[ccxt/{kraken_sym}] Error: {e}\")\n            break\n        if not ohlcv:\n            break\n\n        all_rows.extend(ohlcv)\n        total = len(all_rows)\n        since_ms = ohlcv[-1][0] + 1   # advance to next page\n\n        if len(ohlcv) < limit:\n            break   # reached present\n        time.sleep(0.5)\n\n    if not all_rows:\n        return pd.DataFrame()\n\n    df = pd.DataFrame(all_rows, columns=[\"timestamp\", \"open\", \"high\", \"low\", \"close\", \"volume\"])\n    df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], unit=\"ms\", utc=True)\n    df = df.drop_duplicates(\"timestamp\").sort_values(\"timestamp\").reset_index(drop=True)\n    return df\n\n\n# в”Җв”Җ Master download function with source priority в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\ndef download_full_history(\n    symbol: str,\n    config: dict,\n    min_candles: int = 40_000,\n) -> pd.DataFrame:\n    \"\"\"\n    Priority order:\n      1. yfinance 2-minute (60 days вүҲ 43 200 candles)  вҖ” fastest\n      2. yfinance 1-minute stacked windows             вҖ” most granular, ~7 days\n      3. ccxt Kraken 1-minute                          вҖ” wider history, slower\n    Returns the largest dataset obtained, normalised to our schema.\n    \"\"\"\n    yahoo = config[\"binance_to_yahoo\"].get(symbol, symbol)\n    log.info(f\"[{symbol}] Attempting yfinance 2m (Yahoo: {yahoo})...\")\n\n    # в”Җв”Җ Source 1: yfinance 2-minute в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    df = yf_download_2m(yahoo)\n    if len(df) >= min_candles:\n        log.info(f\"[{symbol}] yfinance 2m: {len(df):,} candles вң“\")\n        return df\n    log.info(f\"[{symbol}] yfinance 2m only returned {len(df):,} rows вҖ” trying 1m stack...\")\n\n    # в”Җв”Җ Source 2: yfinance 1-minute stacked (up to 30 days, 7-day windows) в”Җв”Җв”Җ\n    frames_1m = []\n    for start_offset in range(0, 30, 7):\n        end_dt   = datetime.now(timezone.utc) - timedelta(days=start_offset)\n        start_dt = end_dt - timedelta(days=7)\n        try:\n            chunk = yf.download(\n                yahoo,\n                start=start_dt.strftime(\"%Y-%m-%d\"),\n                end=end_dt.strftime(\"%Y-%m-%d\"),\n                interval=\"1m\",\n                progress=False,\n                auto_adjust=True,\n            )\n            chunk = _normalise_yf(chunk)\n            if not chunk.empty:\n                frames_1m.append(chunk)\n        except Exception as e:\n            log.warning(f\"[{symbol}] 1m chunk error: {e}\")\n        time.sleep(0.3)\n\n    if frames_1m:\n        combined = pd.concat(frames_1m).drop_duplicates(\"timestamp\").sort_values(\"timestamp\").reset_index(drop=True)\n        if len(combined) >= min_candles:\n            log.info(f\"[{symbol}] yfinance 1m stack: {len(combined):,} candles вң“\")\n            return combined\n        log.info(f\"[{symbol}] yfinance 1m stack: {len(combined):,} rows вҖ” trying ccxt...\")\n        # Carry what we have; may top up via ccxt below\n        df = combined\n\n    # в”Җв”Җ Source 3: ccxt Kraken fallback в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    log.info(f\"[{symbol}] Trying ccxt (Kraken) fallback...\")\n    ccxt_df = ccxt_download(symbol, timeframe=\"1m\", min_candles=min_candles)\n    if not ccxt_df.empty:\n        if not df.empty:\n            combined = pd.concat([ccxt_df, df]).drop_duplicates(\"timestamp\").sort_values(\"timestamp\").reset_index(drop=True)\n        else:\n            combined = ccxt_df\n        log.info(f\"[{symbol}] After ccxt merge: {len(combined):,} candles\")\n        return combined\n\n    # в”Җв”Җ Last resort: return whatever we have (may be < min_candles) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    if not df.empty:\n        log.warning(f\"[{symbol}] Best available: {len(df):,} candles (below target {min_candles:,})\")\n        return df\n\n    raise ValueError(f\"Could not fetch any data for {symbol} from any source.\")\n\n\nprint(\"Multi-source downloader defined.\")\nprint(\"Sources: yfinance-2m вҶ’ yfinance-1m-stack вҶ’ ccxt-Kraken\")\nprint(\"Run Cell 6 to download and cache all assets.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:36.299120Z","iopub.execute_input":"2026-03-11T12:23:36.299450Z","iopub.status.idle":"2026-03-11T12:23:36.320875Z","shell.execute_reply.started":"2026-03-11T12:23:36.299426Z","shell.execute_reply":"2026-03-11T12:23:36.320208Z"}},"outputs":[{"name":"stdout","text":"Multi-source downloader defined.\nSources: yfinance-2m вҶ’ yfinance-1m-stack вҶ’ ccxt-Kraken\nRun Cell 6 to download and cache all assets.\n","output_type":"stream"}],"execution_count":24},{"id":"cell-06","cell_type":"code","source":"# =============================================================================\n# CELL 6 вҖ” Cache Manager (Save / Load Parquet) + Incremental yfinance Update\n# =============================================================================\n# First run  : calls multi-source downloader from Cell 5.\n# Subsequent : loads Parquet, appends only new 1m candles via yfinance.\n# Cache path : ./cache/{SYMBOL}_1m.parquet\n\ndef cache_path(symbol: str, cache_dir: str) -> Path:\n    return Path(cache_dir) / f\"{symbol}_1m.parquet\"\n\n\ndef save_to_cache(df: pd.DataFrame, symbol: str, cache_dir: str) -> None:\n    path = cache_path(symbol, cache_dir)\n    df.to_parquet(path, index=False)\n    log.info(f\"[{symbol}] Cached {len(df):,} rows вҶ’ {path}\")\n\n\ndef load_from_cache(symbol: str, cache_dir: str) -> pd.DataFrame | None:\n    path = cache_path(symbol, cache_dir)\n    if path.exists():\n        df = pd.read_parquet(path)\n        df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], utc=True)\n        log.info(f\"[{symbol}] Loaded {len(df):,} cached rows (up to {df['timestamp'].max()})\")\n        return df\n    return None\n\n\ndef fetch_incremental_yf(\n    symbol: str,\n    cached_df: pd.DataFrame,\n    config: dict,\n) -> pd.DataFrame:\n    \"\"\"\n    Fetch only the newest candles (since last cached timestamp) via yfinance 1m.\n    Yahoo caps 1m at 7 days so this is always fast.\n    \"\"\"\n    yahoo     = config[\"binance_to_yahoo\"].get(symbol, symbol)\n    last_ts   = cached_df[\"timestamp\"].max()\n    start_str = last_ts.strftime(\"%Y-%m-%d\")\n    end_str   = datetime.now(timezone.utc).strftime(\"%Y-%m-%d\")\n\n    try:\n        new_raw = yf.download(\n            yahoo,\n            start=start_str,\n            end=end_str,\n            interval=\"1m\",\n            progress=False,\n            auto_adjust=True,\n        )\n        new_df = _normalise_yf(new_raw)\n    except Exception as e:\n        log.warning(f\"[{symbol}] Incremental update failed: {e}\")\n        return cached_df\n\n    if new_df.empty:\n        log.info(f\"[{symbol}] Cache already up-to-date.\")\n        return cached_df\n\n    combined = (\n        pd.concat([cached_df, new_df], ignore_index=True)\n        .drop_duplicates(subset=\"timestamp\")\n        .sort_values(\"timestamp\")\n        .reset_index(drop=True)\n    )\n    log.info(f\"[{symbol}] Incremental update: +{len(new_df):,} rows вҶ’ total {len(combined):,}\")\n    return combined\n\n\ndef get_or_download(symbol: str, config: dict) -> pd.DataFrame:\n    \"\"\"Main entry: load cache вҶ’ update incrementally вҶ’ full download if missing.\"\"\"\n    cached = load_from_cache(symbol, config[\"cache_dir\"])\n\n    if cached is not None:\n        df = fetch_incremental_yf(symbol, cached, config)\n    else:\n        log.info(f\"[{symbol}] No cache вҖ” running full multi-source download...\")\n        df = download_full_history(\n            symbol,\n            config=config,\n            min_candles=40_000,\n        )\n\n    save_to_cache(df, symbol, config[\"cache_dir\"])\n    return df\n\n\n# в”Җв”Җ Download / refresh all assets в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nRAW_DATA: dict[str, pd.DataFrame] = {}\n\nfor asset in CONFIG[\"assets\"]:\n    print(f\"\\nв”Җв”Җв”Җ {asset} в”Җв”Җв”Җ\")\n    RAW_DATA[asset] = get_or_download(asset, CONFIG)\n    df_info = RAW_DATA[asset]\n    print(f\"  Rows  : {len(df_info):,}\")\n    print(f\"  Range : {df_info['timestamp'].min()} вҶ’ {df_info['timestamp'].max()}\")\n\nprint(\"\\n=== All data ready ===\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:36.321957Z","iopub.execute_input":"2026-03-11T12:23:36.322412Z","iopub.status.idle":"2026-03-11T12:23:37.301167Z","shell.execute_reply.started":"2026-03-11T12:23:36.322381Z","shell.execute_reply":"2026-03-11T12:23:37.300255Z"}},"outputs":[{"name":"stderr","text":"2026-03-11 12:23:36,407 | INFO | [BTCUSDT] Loaded 35,470 cached rows (up to 2026-03-11 12:14:00+00:00)\n","output_type":"stream"},{"name":"stdout","text":"\nв”Җв”Җв”Җ BTCUSDT в”Җв”Җв”Җ\n","output_type":"stream"},{"name":"stderr","text":"2026-03-11 12:23:36,500 | INFO | [BTCUSDT] Cache already up-to-date.\n2026-03-11 12:23:36,527 | INFO | [BTCUSDT] Cached 35,470 rows вҶ’ cache/BTCUSDT_1m.parquet\n","output_type":"stream"},{"name":"stdout","text":"  Rows  : 35,470\n  Range : 2026-02-11 00:00:00+00:00 вҶ’ 2026-03-11 12:14:00+00:00\n\nв”Җв”Җв”Җ ETHUSDT в”Җв”Җв”Җ\n","output_type":"stream"},{"name":"stderr","text":"2026-03-11 12:23:36,546 | INFO | [ETHUSDT] Loaded 33,164 cached rows (up to 2026-03-11 12:14:00+00:00)\n2026-03-11 12:23:36,637 | INFO | [ETHUSDT] Cache already up-to-date.\n2026-03-11 12:23:36,658 | INFO | [ETHUSDT] Cached 33,164 rows вҶ’ cache/ETHUSDT_1m.parquet\n","output_type":"stream"},{"name":"stdout","text":"  Rows  : 33,164\n  Range : 2026-02-11 00:00:00+00:00 вҶ’ 2026-03-11 12:14:00+00:00\n\nв”Җв”Җв”Җ BNBUSDT в”Җв”Җв”Җ\n","output_type":"stream"},{"name":"stderr","text":"2026-03-11 12:23:37,000 | INFO | [BNBUSDT] Loaded 34,183 cached rows (up to 2026-03-11 12:14:00+00:00)\n2026-03-11 12:23:37,092 | INFO | [BNBUSDT] Cache already up-to-date.\n2026-03-11 12:23:37,113 | INFO | [BNBUSDT] Cached 34,183 rows вҶ’ cache/BNBUSDT_1m.parquet\n2026-03-11 12:23:37,129 | INFO | [SOLUSDT] Loaded 32,113 cached rows (up to 2026-03-11 12:14:00+00:00)\n2026-03-11 12:23:37,275 | INFO | [SOLUSDT] Cache already up-to-date.\n2026-03-11 12:23:37,296 | INFO | [SOLUSDT] Cached 32,113 rows вҶ’ cache/SOLUSDT_1m.parquet\n","output_type":"stream"},{"name":"stdout","text":"  Rows  : 34,183\n  Range : 2026-02-11 00:00:00+00:00 вҶ’ 2026-03-11 12:14:00+00:00\n\nв”Җв”Җв”Җ SOLUSDT в”Җв”Җв”Җ\n  Rows  : 32,113\n  Range : 2026-02-11 00:00:00+00:00 вҶ’ 2026-03-11 12:14:00+00:00\n\n=== All data ready ===\n","output_type":"stream"}],"execution_count":25},{"id":"cell-07","cell_type":"code","source":"# =============================================================================\n# CELL 7 вҖ” Feature Engineering Pipeline\n# =============================================================================\n# Builds a rich feature set per candle:\n#   - Candlestick geometry (body, wicks, direction)\n#   - Technical indicators via the `ta` library (RSI, MACD, BB, ATR, EMA, Stoch, OBV)\n#   - Volume features (MA, relative volume, spikes)\n#   - Lag returns / direction flags (previous N candles)\n#   - Target label: 0=DOWN, 1=FLAT, 2=UP  (next candle direction)\n\ndef add_candlestick_features(df: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"Body, wick, and direction features derived from OHLC.\"\"\"\n    df = df.copy()\n    df[\"body\"] = df[\"close\"] - df[\"open\"]\n    df[\"body_pct\"] = df[\"body\"] / df[\"open\"]\n    df[\"candle_range\"] = df[\"high\"] - df[\"low\"]\n    df[\"upper_wick\"] = df[\"high\"] - df[[\"open\", \"close\"]].max(axis=1)\n    df[\"lower_wick\"] = df[[\"open\", \"close\"]].min(axis=1) - df[\"low\"]\n    df[\"wick_ratio\"] = (df[\"upper_wick\"] - df[\"lower_wick\"]) / (df[\"candle_range\"] + 1e-9)\n    df[\"is_bullish\"] = (df[\"close\"] > df[\"open\"]).astype(int)\n    return df\n\n\ndef add_technical_indicators(df: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"RSI, MACD, Bollinger Bands, ATR, EMAs, Stochastic, OBV.\"\"\"\n    df = df.copy()\n    close = df[\"close\"]\n    high  = df[\"high\"]\n    low   = df[\"low\"]\n    vol   = df[\"volume\"]\n\n    # RSI\n    df[\"rsi_14\"] = ta.momentum.RSIIndicator(close, window=14).rsi()\n\n    # MACD\n    macd = ta.trend.MACD(close)\n    df[\"macd\"]        = macd.macd()\n    df[\"macd_signal\"] = macd.macd_signal()\n    df[\"macd_diff\"]   = macd.macd_diff()\n\n    # Bollinger Bands\n    bb = ta.volatility.BollingerBands(close, window=20)\n    df[\"bb_upper\"]  = bb.bollinger_hband()\n    df[\"bb_lower\"]  = bb.bollinger_lband()\n    df[\"bb_mid\"]    = bb.bollinger_mavg()\n    df[\"bb_width\"]  = (df[\"bb_upper\"] - df[\"bb_lower\"]) / (df[\"bb_mid\"] + 1e-9)\n    df[\"bb_pct\"]    = bb.bollinger_pband()\n\n    # ATR\n    df[\"atr_14\"] = ta.volatility.AverageTrueRange(high, low, close, window=14).average_true_range()\n\n    # EMAs\n    for w in [5, 10, 20, 50]:\n        df[f\"ema_{w}\"] = ta.trend.EMAIndicator(close, window=w).ema_indicator()\n    # EMA cross features\n    df[\"ema_5_10_cross\"]  = df[\"ema_5\"]  - df[\"ema_10\"]\n    df[\"ema_10_20_cross\"] = df[\"ema_10\"] - df[\"ema_20\"]\n    df[\"ema_20_50_cross\"] = df[\"ema_20\"] - df[\"ema_50\"]\n\n    # Stochastic\n    stoch = ta.momentum.StochasticOscillator(high, low, close)\n    df[\"stoch_k\"] = stoch.stoch()\n    df[\"stoch_d\"] = stoch.stoch_signal()\n\n    # OBV\n    df[\"obv\"] = ta.volume.OnBalanceVolumeIndicator(close, vol).on_balance_volume()\n\n    return df\n\n\ndef add_volume_features(df: pd.DataFrame, windows=(5, 20)) -> pd.DataFrame:\n    \"\"\"Volume moving averages, relative volume, spike flags.\"\"\"\n    df = df.copy()\n    for w in windows:\n        df[f\"vol_ma_{w}\"] = df[\"volume\"].rolling(w).mean()\n    df[\"rel_vol_5\"]  = df[\"volume\"] / (df[\"vol_ma_5\"]  + 1e-9)\n    df[\"rel_vol_20\"] = df[\"volume\"] / (df[\"vol_ma_20\"] + 1e-9)\n    vol_std = df[\"volume\"].rolling(20).std()\n    df[\"vol_spike\"] = ((df[\"volume\"] - df[\"vol_ma_20\"]) / (vol_std + 1e-9)).clip(-5, 5)\n    return df\n\n\ndef add_lag_features(df: pd.DataFrame, n_lags: int = 5) -> pd.DataFrame:\n    \"\"\"Lagged returns and direction flags for the previous n_lags candles.\"\"\"\n    df = df.copy()\n    df[\"return\"] = df[\"close\"].pct_change()\n    for lag in range(1, n_lags + 1):\n        df[f\"ret_lag_{lag}\"]  = df[\"return\"].shift(lag)\n        df[f\"bull_lag_{lag}\"] = df[\"is_bullish\"].shift(lag)\n    return df\n\n\ndef add_target_label(df: pd.DataFrame, flat_threshold: float) -> pd.DataFrame:\n    \"\"\"\n    Target = next candle direction.\n    0 = DOWN  (next close < open by > threshold)\n    1 = FLAT  (abs move вүӨ threshold)\n    2 = UP    (next close > open by > threshold)\n    \"\"\"\n    df = df.copy()\n    next_return = df[\"close\"].pct_change().shift(-1)   # next candle's return\n    conditions = [\n        next_return >  flat_threshold,\n        next_return < -flat_threshold,\n    ]\n    choices = [2, 0]\n    df[\"label\"] = np.select(conditions, choices, default=1)\n    return df\n\n\ndef build_features(df: pd.DataFrame, config: dict) -> pd.DataFrame:\n    \"\"\"Full feature pipeline: apply all transforms then drop NaN rows.\"\"\"\n    df = add_candlestick_features(df)\n    df = add_technical_indicators(df)\n    df = add_volume_features(df)\n    df = add_lag_features(df, n_lags=5)\n    df = add_target_label(df, config[\"flat_threshold\"])\n    df = df.dropna().reset_index(drop=True)\n    return df\n\n\n# в”Җв”Җ Apply to all assets в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nFEAT_DATA: dict[str, pd.DataFrame] = {}\n\nfor asset, raw_df in RAW_DATA.items():\n    print(f\"Building features for {asset}...\")\n    feat_df = build_features(raw_df, CONFIG)\n    FEAT_DATA[asset] = feat_df\n    lbl_counts = feat_df[\"label\"].value_counts().sort_index()\n    print(f\"  Rows  : {len(feat_df):,}\")\n    print(f\"  Labels: DOWN={lbl_counts.get(0,0):,}  FLAT={lbl_counts.get(1,0):,}  UP={lbl_counts.get(2,0):,}\")\n\n# Save feature column names (everything except metadata & target)\nEXCLUDE_COLS = {\"timestamp\", \"label\", \"open_time\", \"close_time\"}\nFEATURE_COLS = [\n    c for c in next(iter(FEAT_DATA.values())).columns\n    if c not in EXCLUDE_COLS\n]\nprint(f\"\\nTotal features: {len(FEATURE_COLS)}\")\nprint(FEATURE_COLS)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:37.302458Z","iopub.execute_input":"2026-03-11T12:23:37.302742Z","iopub.status.idle":"2026-03-11T12:23:38.150634Z","shell.execute_reply.started":"2026-03-11T12:23:37.302718Z","shell.execute_reply":"2026-03-11T12:23:38.149973Z"}},"outputs":[{"name":"stdout","text":"Building features for BTCUSDT...\n  Rows  : 35,421\n  Labels: DOWN=14,177  FLAT=7,188  UP=14,056\nBuilding features for ETHUSDT...\n  Rows  : 33,115\n  Labels: DOWN=13,843  FLAT=5,648  UP=13,624\nBuilding features for BNBUSDT...\n  Rows  : 33,716\n  Labels: DOWN=8,465  FLAT=16,527  UP=8,724\nBuilding features for SOLUSDT...\n  Rows  : 32,064\n  Labels: DOWN=11,500  FLAT=9,434  UP=11,130\n\nTotal features: 48\n['open', 'high', 'low', 'close', 'volume', 'body', 'body_pct', 'candle_range', 'upper_wick', 'lower_wick', 'wick_ratio', 'is_bullish', 'rsi_14', 'macd', 'macd_signal', 'macd_diff', 'bb_upper', 'bb_lower', 'bb_mid', 'bb_width', 'bb_pct', 'atr_14', 'ema_5', 'ema_10', 'ema_20', 'ema_50', 'ema_5_10_cross', 'ema_10_20_cross', 'ema_20_50_cross', 'stoch_k', 'stoch_d', 'obv', 'vol_ma_5', 'vol_ma_20', 'rel_vol_5', 'rel_vol_20', 'vol_spike', 'return', 'ret_lag_1', 'bull_lag_1', 'ret_lag_2', 'bull_lag_2', 'ret_lag_3', 'bull_lag_3', 'ret_lag_4', 'bull_lag_4', 'ret_lag_5', 'bull_lag_5']\n","output_type":"stream"}],"execution_count":26},{"id":"cell-08","cell_type":"code","source":"# =============================================================================\n# CELL 8 вҖ” Dataset Builder (Windowed Sequences + Train/Val/Test Split)\n# =============================================================================\n# Converts flat feature DataFrames into 3-D arrays of shape\n#   (n_samples, window_size, n_features)\n# ready for LSTM input.\n# Split is TIME-ORDERED (no shuffle): 70% train | 15% val | 15% test.\n# Applies RobustScaler fitted on training data only (prevents data leakage).\n\nfrom sklearn.preprocessing import RobustScaler\n\n\ndef make_sequences(\n    df: pd.DataFrame,\n    feature_cols: list,\n    window: int,\n    scaler: RobustScaler = None,\n    fit_scaler: bool = False,\n) -> tuple[np.ndarray, np.ndarray, RobustScaler]:\n    \"\"\"\n    Build windowed sequences.\n    Returns X of shape (N, window, F), y of shape (N,), and the scaler.\n    \"\"\"\n    values = df[feature_cols].values.astype(np.float32)\n\n    if fit_scaler:\n        scaler = RobustScaler()\n        values = scaler.fit_transform(values)\n    elif scaler is not None:\n        values = scaler.transform(values)\n\n    labels = df[\"label\"].values\n\n    X, y = [], []\n    for i in range(window, len(values)):\n        X.append(values[i - window: i])\n        y.append(labels[i])\n\n    return np.array(X, dtype=np.float32), np.array(y, dtype=np.int32), scaler\n\n\ndef time_split(df: pd.DataFrame, ratios=(0.70, 0.15, 0.15)):\n    \"\"\"Split a DataFrame into train / val / test by row index (time order).\"\"\"\n    n = len(df)\n    i1 = int(n * ratios[0])\n    i2 = int(n * (ratios[0] + ratios[1]))\n    return df.iloc[:i1], df.iloc[i1:i2], df.iloc[i2:]\n\n\n# в”Җв”Җ Build datasets for each asset в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nDATASETS: dict[str, dict] = {}\n\nfor asset, feat_df in FEAT_DATA.items():\n    print(f\"\\nBuilding dataset: {asset}\")\n\n    train_df, val_df, test_df = time_split(feat_df)\n    print(f\"  Split sizes: train={len(train_df):,}  val={len(val_df):,}  test={len(test_df):,}\")\n\n    # Fit scaler on training data only\n    X_train, y_train, scaler = make_sequences(\n        train_df, FEATURE_COLS, CONFIG[\"window_size\"], fit_scaler=True\n    )\n    X_val, y_val, _ = make_sequences(\n        val_df, FEATURE_COLS, CONFIG[\"window_size\"], scaler=scaler\n    )\n    X_test, y_test, _ = make_sequences(\n        test_df, FEATURE_COLS, CONFIG[\"window_size\"], scaler=scaler\n    )\n\n    print(f\"  X_train: {X_train.shape} | y_train: {y_train.shape}\")\n    print(f\"  X_val  : {X_val.shape}   | y_val  : {y_val.shape}\")\n    print(f\"  X_test : {X_test.shape}  | y_test : {y_test.shape}\")\n\n    DATASETS[asset] = {\n        \"X_train\": X_train, \"y_train\": y_train,\n        \"X_val\":   X_val,   \"y_val\":   y_val,\n        \"X_test\":  X_test,  \"y_test\":  y_test,\n        \"scaler\":  scaler,\n        \"n_features\": X_train.shape[2],\n    }\n\nprint(\"\\n=== All datasets ready ===\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:38.151635Z","iopub.execute_input":"2026-03-11T12:23:38.151864Z","iopub.status.idle":"2026-03-11T12:23:38.963724Z","shell.execute_reply.started":"2026-03-11T12:23:38.151842Z","shell.execute_reply":"2026-03-11T12:23:38.962997Z"}},"outputs":[{"name":"stdout","text":"\nBuilding dataset: BTCUSDT\n  Split sizes: train=24,794  val=5,313  test=5,314\n  X_train: (24734, 60, 48) | y_train: (24734,)\n  X_val  : (5253, 60, 48)   | y_val  : (5253,)\n  X_test : (5254, 60, 48)  | y_test : (5254,)\n\nBuilding dataset: ETHUSDT\n  Split sizes: train=23,180  val=4,967  test=4,968\n  X_train: (23120, 60, 48) | y_train: (23120,)\n  X_val  : (4907, 60, 48)   | y_val  : (4907,)\n  X_test : (4908, 60, 48)  | y_test : (4908,)\n\nBuilding dataset: BNBUSDT\n  Split sizes: train=23,601  val=5,057  test=5,058\n  X_train: (23541, 60, 48) | y_train: (23541,)\n  X_val  : (4997, 60, 48)   | y_val  : (4997,)\n  X_test : (4998, 60, 48)  | y_test : (4998,)\n\nBuilding dataset: SOLUSDT\n  Split sizes: train=22,444  val=4,810  test=4,810\n  X_train: (22384, 60, 48) | y_train: (22384,)\n  X_val  : (4750, 60, 48)   | y_val  : (4750,)\n  X_test : (4750, 60, 48)  | y_test : (4750,)\n\n=== All datasets ready ===\n","output_type":"stream"}],"execution_count":27},{"id":"cell-09","cell_type":"code","source":"# =============================================================================\n# CELL 9 вҖ” Model Definition: Bidirectional LSTM + Multi-Head Attention\n# =============================================================================\n# Architecture:\n#   Input  вҶ’ Conv1D (local patterns) вҶ’ BiLSTM stack вҶ’ Multi-Head Attention\n#          вҶ’ GlobalAveragePooling вҶ’ Dense head вҶ’ Softmax [DOWN, FLAT, UP]\n# The model returns both class probabilities (for RL reward) and the argmax.\n\ndef build_model(\n    window_size: int,\n    n_features: int,\n    lstm_units: list,\n    dropout: float,\n    n_classes: int = 3,\n    learning_rate: float = 1e-3,\n) -> keras.Model:\n    \"\"\"\n    Returns a compiled Keras model.\n    Input shape: (batch, window_size, n_features)\n    Output shape: (batch, 3)  вҖ” softmax probabilities\n    \"\"\"\n    inp = keras.Input(shape=(window_size, n_features), name=\"ohlcv_sequence\")\n\n    # в”Җв”Җ Local pattern extraction via Conv1D в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    x = layers.Conv1D(filters=64, kernel_size=3, padding=\"causal\",\n                      activation=\"relu\", name=\"conv1d\")(inp)\n    x = layers.BatchNormalization()(x)\n\n    # в”Җв”Җ Bidirectional LSTM stack в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    for i, units in enumerate(lstm_units):\n        return_seq = True  # always True so Attention sees the full sequence\n        x = layers.Bidirectional(\n            layers.LSTM(units, return_sequences=return_seq,\n                        recurrent_dropout=0.0),\n            name=f\"bilstm_{i}\"\n        )(x)\n        x = layers.Dropout(dropout)(x)\n\n    # в”Җв”Җ Multi-Head Attention в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    attn_out = layers.MultiHeadAttention(\n        num_heads=4, key_dim=lstm_units[-1] // 4, name=\"mha\"\n    )(x, x)\n    x = layers.Add()([x, attn_out])          # residual connection\n    x = layers.LayerNormalization()(x)\n\n    # в”Җв”Җ Pool & classify в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    x = layers.GlobalAveragePooling1D()(x)\n    x = layers.Dense(64, activation=\"relu\")(x)\n    x = layers.Dropout(dropout)(x)\n    out = layers.Dense(n_classes, activation=\"softmax\", name=\"direction\")(x)\n\n    model = keras.Model(inputs=inp, outputs=out, name=\"BiLSTM_Attention\")\n\n    model.compile(\n        optimizer=keras.optimizers.Adam(learning_rate=learning_rate),\n        loss=\"sparse_categorical_crossentropy\",\n        metrics=[\"accuracy\"]\n    )\n    return model\n\n\n# Quick sanity check with the first asset\nsample_asset = CONFIG[\"assets\"][0]\nsample_ds    = DATASETS[sample_asset]\n\ntest_model = build_model(\n    window_size  = CONFIG[\"window_size\"],\n    n_features   = sample_ds[\"n_features\"],\n    lstm_units   = CONFIG[\"lstm_units\"],\n    dropout      = CONFIG[\"dropout\"],\n    learning_rate= CONFIG[\"learning_rate\"],\n)\ntest_model.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:38.964765Z","iopub.execute_input":"2026-03-11T12:23:38.965034Z","iopub.status.idle":"2026-03-11T12:23:39.115780Z","shell.execute_reply.started":"2026-03-11T12:23:38.965014Z","shell.execute_reply":"2026-03-11T12:23:39.115193Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"BiLSTM_Attention\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"BiLSTM_Attention\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"в”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\nв”ғ\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0mв”ғ\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0mв”ғ\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0mв”ғ\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0mв”ғ\nв”Ўв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”©\nв”Ӯ ohlcv_sequence      в”Ӯ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m60\u001b[0m, \u001b[38;5;34m48\u001b[0m)    в”Ӯ          \u001b[38;5;34m0\u001b[0m в”Ӯ -                 в”Ӯ\nв”Ӯ (\u001b[38;5;33mInputLayer\u001b[0m)        в”Ӯ                   в”Ӯ            в”Ӯ                   в”Ӯ\nв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”