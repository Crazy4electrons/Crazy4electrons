uracy                         0.5764      4998\n   macro avg     0.4653    0.3542    0.2960      4998\nweighted avg     0.5083    0.5764    0.4516      4998\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x500 with 4 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Plot saved вҶ’ ./models/BNBUSDT_evaluation.png\n\n============================================================\n Evaluation: SOLUSDT\n============================================================\nOverall test accuracy : 0.3360 (33.60%)\nNo samples met confidence threshold.\n80% target: вң— Below 80% target\n\nClassification Report:\n              precision    recall  f1-score   support\n\n        DOWN     0.3316    0.9526    0.4920      1582\n        FLAT     0.4368    0.0232    0.0441      1638\n          UP     0.4286    0.0333    0.0619      1530\n\n    accuracy                         0.3360      4750\n   macro avg     0.3990    0.3364    0.1993      4750\nweighted avg     0.3991    0.3360    0.1990      4750\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x500 with 4 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Plot saved вҶ’ ./models/SOLUSDT_evaluation.png\n\n=======================================================\nAsset         Overall Acc  Tradeable Acc\n-------------------------------------------------------\nBTCUSDT           0.3917        0.0000  вң—\nETHUSDT           0.4026        0.0000  вң—\nBNBUSDT           0.5764        0.0000  вң—\nSOLUSDT           0.3360        0.0000  вң—\n=======================================================\n","output_type":"stream"}],"execution_count":31},{"id":"cell-13","cell_type":"code","source":"# =============================================================================\n# CELL 13 вҖ” Live Inference Engine\n# =============================================================================\n# InferenceEngine wraps a trained model + scaler.\n# Given the latest `window_size` feature rows, it returns:\n#   - predicted class (0=DOWN, 1=FLAT, 2=UP)\n#   - confidence score (max softmax probability)\n#   - full probability vector\n# Also contains a rolling buffer that ingests real-time candle dicts.\n\nclass InferenceEngine:\n    \"\"\"\n    Wraps a trained Keras model for real-time inference.\n    Compatible with candle dicts emitted by:\n      api.subscribe_symbol()          (subscribe_symbol.py)\n      api.subscribe_symbol_timed()    (subscribe_symbol_timed.py)\n    \"\"\"\n\n    def __init__(\n        self,\n        model: keras.Model,\n        scaler: RobustScaler,\n        feature_cols: list,\n        window_size: int,\n        config: dict,\n    ):\n        self.model        = model\n        self.scaler       = scaler\n        self.feature_cols = feature_cols\n        self.window_size  = window_size\n        self.config       = config\n        self.label_map    = config[\"label_map\"]\n        self.min_conf     = config[\"min_confidence\"]\n\n        # Rolling buffer of raw candle dicts\n        self._buffer: deque = deque(maxlen=window_size + 200)  # extra room for indicators\n\n    def ingest(self, candle: dict) -> None:\n        \"\"\"Add a new candle dict (with OHLCV keys) to the rolling buffer.\"\"\"\n        self._buffer.append(candle)\n\n    @property\n    def ready(self) -> bool:\n        \"\"\"True once buffer has enough candles to compute all features.\"\"\"\n        return len(self._buffer) >= self.window_size + 60   # 60 = max indicator window\n\n    def _build_feature_row(self) -> np.ndarray | None:\n        \"\"\"Convert buffer вҶ’ feature DataFrame вҶ’ last window_size rows.\"\"\"\n        df = pd.DataFrame(list(self._buffer))\n\n        # Normalise column names (API may use 'time' or 'timestamp')\n        if \"time\" in df.columns and \"timestamp\" not in df.columns:\n            df.rename(columns={\"time\": \"timestamp\"}, inplace=True)\n\n        for col in [\"open\", \"high\", \"low\", \"close\", \"volume\"]:\n            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n\n        df = build_features(df, self.config)\n\n        if len(df) < self.window_size:\n            return None\n\n        window = df[self.feature_cols].values[-self.window_size:].astype(np.float32)\n        window = self.scaler.transform(window)       # apply training scaler\n        return window\n\n    def predict(self) -> dict | None:\n        \"\"\"\n        Run inference on the current buffer.\n        Returns dict with keys: class, label, confidence, probs\n        or None if buffer not ready.\n        \"\"\"\n        if not self.ready:\n            return None\n\n        window = self._build_feature_row()\n        if window is None:\n            return None\n\n        X = window[np.newaxis, ...]   # (1, window, features)\n        probs      = self.model.predict(X, verbose=0)[0]\n        pred_class = int(np.argmax(probs))\n        confidence = float(probs[pred_class])\n\n        return {\n            \"class\":      pred_class,\n            \"label\":      self.label_map[pred_class],\n            \"confidence\": confidence,\n            \"probs\":      probs.tolist(),\n            \"tradeable\":  confidence >= self.min_conf and pred_class != 1,\n        }\n\n\n# в”Җв”Җ Instantiate engines for all trained assets в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nENGINES: dict[str, InferenceEngine] = {}\n\nfor asset in CONFIG[\"assets\"]:\n    ENGINES[asset] = InferenceEngine(\n        model        = TRAINED_MODELS[asset],\n        scaler       = DATASETS[asset][\"scaler\"],\n        feature_cols = FEATURE_COLS,\n        window_size  = CONFIG[\"window_size\"],\n        config       = CONFIG,\n    )\n    print(f\"Inference engine ready: {asset}\")\n\nprint(\"\\nTest inference using last test-window from dataset:\")\nsample_engine = ENGINES[CONFIG[\"assets\"][0]]\nsample_X = DATASETS[CONFIG[\"assets\"][0]][\"X_test\"][-1]\n# Feed the scaler-transformed window directly for testing\nsample_engine.model.predict(sample_X[np.newaxis], verbose=0)\nprobs = sample_engine.model.predict(sample_X[np.newaxis], verbose=0)[0]\nprint(f\"  Probs  : DOWN={probs[0]:.3f}  FLAT={probs[1]:.3f}  UP={probs[2]:.3f}\")\nprint(f\"  Signal : {CONFIG['label_map'][int(np.argmax(probs))]}  (conf={float(np.max(probs)):.3f})\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:29:49.661384Z","iopub.execute_input":"2026-03-11T12:29:49.662022Z","iopub.status.idle":"2026-03-11T12:29:49.859761Z","shell.execute_reply.started":"2026-03-11T12:29:49.661999Z","shell.execute_reply":"2026-03-11T12:29:49.859182Z"}},"outputs":[{"name":"stdout","text":"Inference engine ready: BTCUSDT\nInference engine ready: ETHUSDT\nInference engine ready: BNBUSDT\nInference engine ready: SOLUSDT\n\nTest inference using last test-window from dataset:\n  Probs  : DOWN=0.477  FLAT=0.108  UP=0.415\n  Signal : DOWN  (conf=0.477)\n","output_type":"stream"}],"execution_count":32},{"id":"cell-14","cell_type":"code","source":"# =============================================================================\n# CELL 14 вҖ” Online RL Update Loop (Live Reinforcement Learning)\n# =============================================================================\n# After each completed trade:\n#   1. The trade outcome is converted to an RL reward.\n#   2. The (X, y_true) pair is stored in a circular replay buffer.\n#   3. Every `online_update_every` trades, a mini-batch gradient update\n#      is performed on the top layers only (base layers frozen for stability).\n#   4. Weights are saved periodically.\n\nclass OnlineRLUpdater:\n    \"\"\"\n    Handles incremental model updates from live trade outcomes.\n    Designed to be called after api.check_win() returns вҖ” see check_win.py.\n    \"\"\"\n\n    def __init__(\n        self,\n        model: keras.Model,\n        scaler: RobustScaler,\n        feature_cols: list,\n        window_size: int,\n        config: dict,\n        asset: str,\n    ):\n        self.model        = model\n        self.scaler       = scaler\n        self.feature_cols = feature_cols\n        self.window_size  = window_size\n        self.config       = config\n        self.asset        = asset\n\n        self.replay_buffer: deque = deque(maxlen=config[\"replay_buffer_size\"])\n        self.trade_count   = 0\n        self.total_reward  = 0.0\n\n        # Freeze bottom layers вҖ” only fine-tune the classification head\n        for layer in model.layers[:-4]:\n            layer.trainable = False\n        model.compile(\n            optimizer=keras.optimizers.Adam(1e-4),   # lower LR for fine-tuning\n            loss=rl_weighted_loss(config[\"rl_penalty_multiplier\"]),\n            metrics=[\"accuracy\"]\n        )\n\n    def record_trade(\n        self,\n        X_window: np.ndarray,    # (window, features) вҖ” scaled\n        prediction: int,         # 0/1/2\n        true_outcome: int,       # 0/1/2  (from check_win result)\n    ) -> float:\n        \"\"\"\n        Record a completed trade.\n        Returns the RL reward for this trade.\n        Maps Pocket Option result strings to labels:\n          'win'  вҶ’ prediction was correct\n          'loss' вҶ’ prediction was wrong (opposite direction assumed)\n          'draw' вҶ’ treated as FLAT\n        \"\"\"\n        reward = compute_rl_reward(\n            prediction, true_outcome, self.config[\"rl_penalty_multiplier\"]\n        )\n        self.total_reward += reward\n        self.trade_count  += 1\n        self.replay_buffer.append((X_window, true_outcome))\n\n        if self.trade_count % self.config[\"online_update_every\"] == 0:\n            loss_val = self._gradient_update()\n            log.info(\n                f\"[{self.asset}] Online update #{self.trade_count // self.config['online_update_every']} \"\n                f\"| loss={loss_val:.4f} | cum_reward={self.total_reward:.1f}\"\n            )\n            self._maybe_save()\n\n        return reward\n\n    def _gradient_update(self) -> float:\n        \"\"\"Sample from replay buffer and perform one mini-batch update.\"\"\"\n        batch_size = min(self.config[\"online_batch_size\"], len(self.replay_buffer))\n        indices    = np.random.choice(len(self.replay_buffer), batch_size, replace=False)\n        batch      = [self.replay_buffer[i] for i in indices]\n\n        X_batch = np.array([item[0] for item in batch], dtype=np.float32)\n        y_batch = np.array([item[1] for item in batch], dtype=np.int32)\n\n        result = self.model.train_on_batch(X_batch, y_batch)\n        return float(result[0]) if isinstance(result, (list, tuple)) else float(result)\n\n    def _maybe_save(self) -> None:\n        \"\"\"Save updated weights every 50 updates.\"\"\"\n        n_updates = self.trade_count // self.config[\"online_update_every\"]\n        if n_updates % 50 == 0:\n            ts   = datetime.now().strftime(\"%Y%m%d_%H%M\")\n            path = os.path.join(\n                self.config[\"model_dir\"],\n                f\"model_{self.asset}_online_{ts}.keras\"\n            )\n            self.model.save(path)\n            log.info(f\"[{self.asset}] Online model checkpoint вҶ’ {path}\")\n\n    @staticmethod\n    def pocket_result_to_label(result_str: str, prediction: int) -> int:\n        \"\"\"\n        Convert PocketOption check_win result string to a label.\n        result_str: 'win' | 'loss' | 'draw'\n        prediction: the direction we bet (0 or 2; never 1 since we skip FLAT)\n        \"\"\"\n        if result_str == \"win\":\n            return prediction                 # our prediction was correct\n        elif result_str == \"draw\":\n            return 1                          # treat as FLAT\n        else:  # loss\n            return 2 if prediction == 0 else 0   # opposite direction\n\n\n# в”Җв”Җ Instantiate updaters в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nRL_UPDATERS: dict[str, OnlineRLUpdater] = {}\n\nfor asset in CONFIG[\"assets\"]:\n    RL_UPDATERS[asset] = OnlineRLUpdater(\n        model        = TRAINED_MODELS[asset],\n        scaler       = DATASETS[asset][\"scaler\"],\n        feature_cols = FEATURE_COLS,\n        window_size  = CONFIG[\"window_size\"],\n        config       = CONFIG,\n        asset        = asset,\n    )\n    print(f\"RL updater ready: {asset}\")\n\nprint(\"\\nOnline RL updaters initialised. \"\n      \"Call RL_UPDATERS[asset].record_trade() after each completed trade.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:29:49.860741Z","iopub.execute_input":"2026-03-11T12:29:49.860989Z","iopub.status.idle":"2026-03-11T12:29:49.955853Z","shell.execute_reply.started":"2026-03-11T12:29:49.860963Z","shell.execute_reply":"2026-03-11T12:29:49.955261Z"}},"outputs":[{"name":"stdout","text":"RL updater ready: BTCUSDT\nRL updater ready: ETHUSDT\nRL updater ready: BNBUSDT\nRL updater ready: SOLUSDT\n\nOnline RL updaters initialised. Call RL_UPDATERS[asset].record_trade() after each completed trade.\n","output_type":"stream"}],"execution_count":33},{"id":"cell-15","cell_type":"code","source":"# =============================================================================\n# CELL 15 вҖ” BinaryOptionsV2 Trading Wrapper (Phase 5)\n# =============================================================================\n# Integrates inference + RL update + Pocket Option API.\n#\n# Depends on BinaryOptionsToolsV2 library (see trade.py, check_win.py,\n# subscribe_symbol_timed.py, get_balance.py from the project examples).\n#\n# Risk controls:\n#   - Skip FLAT predictions and low-confidence signals\n#   - Fixed fractional sizing (2% of balance)\n#   - Max 3 consecutive losses вҶ’ 10-minute cooldown\n#   - Daily loss limit (20% of starting balance)\n#   - Hard stop if balance < $10\n#\n# NOTE: Uncomment and run ONLY after Phases 1вҖ“4 are validated.\n#       Requires: pip install BinaryOptionsToolsV2\n\n# from BinaryOptionsToolsV2.pocketoption import PocketOptionAsync\n# from BinaryOptionsToolsV2.tracing import start_logs\n# from datetime import timedelta\n# import asyncio, csv\n\nTRADE_LOG_PATH = \"./trade_log.csv\"\n\nRISK = {\n    \"fraction\":          0.02,    # 2% of balance per trade\n    \"min_balance\":       10.00,   # halt below this\n    \"max_consec_losses\": 3,       # consecutive losses before cooldown\n    \"cooldown_secs\":     600,     # 10 minutes\n    \"daily_loss_limit\":  0.20,    # 20% of starting balance\n    \"trade_duration_s\":  60,      # 1-minute binary option\n}\n\nclass TradingBot:\n    \"\"\"\n    Orchestrates: candle stream вҶ’ inference вҶ’ trade вҶ’ check_win вҶ’ RL update.\n    Follows patterns from trade.py, check_win.py, subscribe_symbol_timed.py.\n    \"\"\"\n\n    def __init__(self, ssid: str, asset: str, config: dict, risk: dict):\n        self.ssid         = ssid\n        self.asset        = asset          # Pocket Option OTC symbol e.g. 'BTCOTC'\n        self.config       = config\n        self.risk         = risk\n        self.engine       = ENGINES[config[\"otc_to_binance\"][asset]]\n        self.updater      = RL_UPDATERS[config[\"otc_to_binance\"][asset]]\n\n        self.balance        = 0.0\n        self.start_balance  = 0.0\n        self.daily_loss     = 0.0\n        self.consec_losses  = 0\n        self.in_cooldown    = False\n        self.cooldown_until = 0.0\n        self.total_trades   = 0\n        self.total_wins     = 0\n\n    def _log_trade(self, row: dict) -> None:\n        exists = os.path.exists(TRADE_LOG_PATH)\n        with open(TRADE_LOG_PATH, \"a\", newline=\"\") as f:\n            writer = csv.DictWriter(f, fieldnames=row.keys())\n            if not exists:\n                writer.writeheader()\n            writer.writerow(row)\n\n    def _position_size(self) -> float:\n        \"\"\"Fixed fractional sizing, clipped to [$1, balance/2].\"\"\"\n        size = round(self.balance * self.risk[\"fraction\"], 2)\n        return max(1.0, min(size, self.balance / 2))\n\n    def _check_risk(self) -> tuple[bool, str]:\n        \"\"\"Returns (can_trade, reason_if_not).\"\"\"\n        if self.balance < self.risk[\"min_balance\"]:\n            return False, f\"Balance ${self.balance:.2f} below minimum ${self.risk['min_balance']:.2f}\"\n        if self.daily_loss >= self.start_balance * self.risk[\"daily_loss_limit\"]:\n            return False, f\"Daily loss limit hit (${self.daily_loss:.2f})\"\n        if self.in_cooldown:\n            remaining = self.cooldown_until - time.time()\n            if remaining > 0:\n                return False, f\"Cooldown: {remaining:.0f}s remaining\"\n            self.in_cooldown = False\n            self.consec_losses = 0\n        return True, \"\"\n\n    # async def run(self):\n    #     \"\"\"\n    #     Main async loop вҖ” uncomment to run live.\n    #     Follows subscribe_symbol_timed.py pattern for candle streaming.\n    #     \"\"\"\n    #     start_logs(\".\", \"INFO\", terminal=True)\n    #     async with PocketOptionAsync(self.ssid) as api:\n    #         self.balance = await api.balance()\n    #         self.start_balance = self.balance\n    #         log.info(f\"[{self.asset}] Starting balance: ${self.balance:.2f}\")\n    #\n    #         stream = await api.subscribe_symbol_timed(\n    #             self.asset, timedelta(seconds=RISK[\"trade_duration_s\"])\n    #         )\n    #\n    #         async for candle in stream:\n    #             self.engine.ingest(candle)    # feed real-time candle\n    #             if not self.engine.ready:\n    #                 continue\n    #\n    #             signal = self.engine.predict()\n    #             if signal is None or not signal[\"tradeable\"]:\n    #                 log.info(f\"[{self.asset}] Skip вҖ” {signal}\")\n    #                 continue\n    #\n    #             can_trade, reason = self._