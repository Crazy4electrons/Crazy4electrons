aved вҶ’ ./models/model_SOLUSDT_20260311_1227_scaler.pkl\n  Best model  вҶ’ ./models/model_SOLUSDT_20260311_1227.keras\n\n=== Training complete for all assets ===\n","output_type":"stream"}],"execution_count":30},{"id":"cell-12","cell_type":"code","source":"# =============================================================================\n# CELL 12 вҖ” Evaluation & Metrics\n# =============================================================================\n# For each asset:\n#   1. Training / validation accuracy curves\n#   2. Confusion matrix (DOWN / FLAT / UP)\n#   3. Classification report (precision, recall, F1)\n#   4. Confidence calibration histogram\n#   5. \"Tradeable\" accuracy вҖ” accuracy when confidence вүҘ min_confidence\n\ndef evaluate_model(\n    model: keras.Model,\n    ds: dict,\n    asset: str,\n    history: dict,\n    config: dict,\n):\n    label_names = [\"DOWN\", \"FLAT\", \"UP\"]\n    min_conf    = config[\"min_confidence\"]\n\n    print(f\"\\n{'='*60}\")\n    print(f\" Evaluation: {asset}\")\n    print(f\"{'='*60}\")\n\n    # в”Җв”Җ Predict on test set в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    probs  = model.predict(ds[\"X_test\"], verbose=0)\n    preds  = np.argmax(probs, axis=1)\n    conf   = np.max(probs, axis=1)\n    y_true = ds[\"y_test\"]\n\n    # в”Җв”Җ Overall accuracy в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    overall_acc = accuracy_score(y_true, preds)\n    print(f\"Overall test accuracy : {overall_acc:.4f} ({overall_acc*100:.2f}%)\")\n\n    # в”Җв”Җ Tradeable accuracy (confidence filtered) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    high_conf_mask = (conf >= min_conf) & (preds != 1)   # exclude FLAT\n    if high_conf_mask.sum() > 0:\n        tradeable_acc = accuracy_score(y_true[high_conf_mask], preds[high_conf_mask])\n        print(f\"Tradeable accuracy   : {tradeable_acc:.4f} ({tradeable_acc*100:.2f}%) \"\n              f\"on {high_conf_mask.sum():,} samples (conf вүҘ {min_conf})\")\n    else:\n        tradeable_acc = 0.0\n        print(\"No samples met confidence threshold.\")\n\n    target_met = \"вң“ TARGET MET\" if tradeable_acc >= 0.80 else \"вң— Below 80% target\"\n    print(f\"80% target: {target_met}\")\n\n    # в”Җв”Җ Classification report в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\nClassification Report:\")\n    print(classification_report(y_true, preds, target_names=label_names, digits=4))\n\n    # в”Җв”Җ Plots в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n    fig.suptitle(f\"{asset} вҖ” Model Evaluation\", fontsize=14, fontweight=\"bold\")\n\n    # Learning curves\n    ax = axes[0]\n    ax.plot(history[\"accuracy\"],     label=\"Train Acc\")\n    ax.plot(history[\"val_accuracy\"], label=\"Val Acc\")\n    ax.axhline(0.80, color=\"red\", linestyle=\"--\", linewidth=1, label=\"80% target\")\n    ax.set_title(\"Accuracy Curves\")\n    ax.set_xlabel(\"Epoch\")\n    ax.legend()\n    ax.grid(alpha=0.3)\n\n    # Confusion matrix\n    ax = axes[1]\n    cm = confusion_matrix(y_true, preds)\n    sns.heatmap(\n        cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n        xticklabels=label_names, yticklabels=label_names, ax=ax\n    )\n    ax.set_title(\"Confusion Matrix (Test)\")\n    ax.set_ylabel(\"True\")\n    ax.set_xlabel(\"Predicted\")\n\n    # Confidence distribution\n    ax = axes[2]\n    ax.hist(conf[preds != 1], bins=40, color=\"steelblue\", alpha=0.7, label=\"Non-FLAT\")\n    ax.axvline(min_conf, color=\"red\", linestyle=\"--\", label=f\"Threshold {min_conf}\")\n    ax.set_title(\"Confidence Distribution\")\n    ax.set_xlabel(\"Max Softmax Probability\")\n    ax.legend()\n    ax.grid(alpha=0.3)\n\n    plt.tight_layout()\n    plot_path = os.path.join(CONFIG[\"model_dir\"], f\"{asset}_evaluation.png\")\n    plt.savefig(plot_path, dpi=120)\n    plt.show()\n    print(f\"Plot saved вҶ’ {plot_path}\")\n\n    return {\"overall_acc\": overall_acc, \"tradeable_acc\": tradeable_acc}\n\n\n# в”Җв”Җ Evaluate all assets в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nEVAL_RESULTS: dict[str, dict] = {}\n\nfor asset in CONFIG[\"assets\"]:\n    EVAL_RESULTS[asset] = evaluate_model(\n        model   = TRAINED_MODELS[asset],\n        ds      = DATASETS[asset],\n        asset   = asset,\n        history = HISTORIES[asset],\n        config  = CONFIG,\n    )\n\n# Summary table\nprint(\"\\n\" + \"=\"*55)\nprint(f\"{'Asset':<12} {'Overall Acc':>12} {'Tradeable Acc':>14}\")\nprint(\"-\"*55)\nfor asset, res in EVAL_RESULTS.items():\n    flag = \"вң“\" if res[\"tradeable_acc\"] >= 0.80 else \"вң—\"\n    print(f\"{asset:<12} {res['overall_acc']:>11.4f}  {res['tradeable_acc']:>12.4f}  {flag}\")\nprint(\"=\"*55)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:29:38.003982Z","iopub.execute_input":"2026-03-11T12:29:38.004239Z","iopub.status.idle":"2026-03-11T12:29:49.659111Z","shell.execute_reply.started":"2026-03-11T12:29:38.004217Z","shell.execute_reply":"2026-03-11T12:29:49.658460Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n Evaluation: BTCUSDT\n============================================================\nOverall test accuracy : 0.3917 (39.17%)\nNo samples met confidence threshold.\n80% target: вң— Below 80% target\n\nClassification Report:\n              precision    