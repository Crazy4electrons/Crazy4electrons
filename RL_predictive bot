white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">413,187</span> (1.58 MB)\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m128\u001b[0m (512.00 B)\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">128</span> (512.00 B)\n</pre>\n"},"metadata":{}}],"execution_count":28},{"id":"cell-10","cell_type":"code","source":"# =============================================================================\n# CELL 10 вҖ” RL Reward Function & Custom RL-Weighted Loss\n# =============================================================================\n# Two components:\n#   A) A reward calculator used during LIVE online RL updates (Phase 4).\n#   B) A custom Keras loss that embeds the RL reward signal into supervised\n#      pre-training (penalises wrong-direction predictions more heavily).\n#      Flat predictions are penalised lightly since we skip them in trading.\n\ndef compute_rl_reward(\n    prediction: int,   # 0=DOWN, 1=FLAT, 2=UP\n    true_label: int,   # ground truth\n    penalty_mult: float = 1.5,\n) -> float:\n    \"\"\"\n    Reward schedule:\n      Correct direction (UP or DOWN) вҶ’  +1.0\n      FLAT prediction               вҶ’   0.0  (no trade, no penalty)\n      Wrong direction               вҶ’  -penalty_mult\n    \"\"\"\n    if prediction == 1:                    # flat вҖ” no trade placed\n        return 0.0\n    if prediction == true_label:\n        return 1.0\n    return -penalty_mult\n\n\ndef rl_weighted_loss(penalty_mult: float = 1.5):\n    \"\"\"\n    Factory that returns a Keras loss function.\n    Wrong directional predictions (DOWNвҶ”UP) get penalty_mult Г— CE loss.\n    FLAT errors get 0.5 Г— CE loss (we rarely trade FLAT).\n    Correct predictions get 1.0 Г— CE loss (standard).\n\n    Fix: tf.squeeze() on y_true can produce an unknown-rank tensor during\n    Keras graph tracing, which breaks sparse_categorical_crossentropy.\n    Solution: use tf.reshape(y_true, [-1]) to guarantee a 1-D tensor,\n    then cast вҖ” this preserves rank information through the tf.function trace.\n    \"\"\"\n    def loss_fn(y_true, y_pred):\n        # Flatten to 1-D with an explicit shape вҖ” avoids unknown-rank error\n        y_true    = tf.cast(tf.reshape(y_true, [-1]), tf.int32)\n        pred_cls  = tf.argmax(y_pred, axis=-1, output_type=tf.int32)\n\n        # Base per-sample cross-entropy (shape: [batch])\n        ce = tf.keras.losses.sparse_categorical_crossentropy(\n            tf.cast(y_true, tf.float32), y_pred\n        )\n\n        # в”Җв”Җ Per-sample RL weight в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        is_flat_pred    = tf.equal(pred_cls, tf.ones_like(pred_cls))   # pred == FLAT\n        is_correct      = tf.equal(pred_cls, y_true)                   # pred == truth\n        wrong_direction = tf.logical_and(\n            tf.logical_not(is_correct),\n            tf.logical_not(is_flat_pred),\n        )\n\n        # Start with weight=1 for every sample, then override:\n        ones   = tf.ones_like(ce)                      # correct  вҶ’ 1.0 Г— CE\n        flat_w = tf.fill(tf.shape(ce), 0.5)            # flat pred вҶ’ 0.5 Г— CE\n        bad_w  = tf.fill(tf.shape(ce), float(penalty_mult))  # wrong dir вҶ’ mult Г— CE\n\n        weights = tf.where(is_flat_pred,    flat_w, ones)\n        weights = tf.where(wrong_direction, bad_w,  weights)\n        # is_correct stays at 1.0 (already set above as the default)\n\n        return tf.reduce_mean(ce * weights)\n\n    loss_fn.__name__ = \"rl_weighted_loss\"\n    return loss_fn\n\n\nprint(\"RL reward function and custom loss defined.\")\nprint(\"Examples:\")\nfor pred, true in [(2, 2), (0, 0), (1, 2), (2, 0), (0, 2)]:\n    r = compute_rl_reward(pred, true, CONFIG[\"rl_penalty_multiplier\"])\n    print(f\"  pred={CONFIG['label_map'][pred]:4s}  true={CONFIG['label_map'][true]:4s}  вҶ’ reward={r:+.1f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T12:23:39.116605Z","iopub.execute_input":"2026-03-11T12:23:39.116794Z","iopub.status.idle":"2026-03-11T12:23:39.126778Z","shell.execute_reply.started":"2026-03-11T12:23:39.116777Z","shell.execute_reply":"2026-03-11T12:23:39.126207Z"}},"outputs":[{"name":"stdout","text":"RL reward function and custom loss defined.\nExamples:\n  pred=UP    true=UP    вҶ’ reward=+1.0\n  pred=DOWN  true=DOWN  вҶ’ reward=+1.0\n  pred=FLAT  true=UP    вҶ’ reward=+0.0\n  pred=UP    true=DOWN  вҶ’ reward=-1.5\n  pred=DOWN  true=UP    вҶ’ reward=-1.5\n","output_type":"stream"}],"execution_count":29},{"id":"cell-11","cell_type":"code","source":"# =============================================================================\n# CELL 11 вҖ” Training Loop with Callbacks\n# =============================================================================\n# Trains one model per asset.\n# Callbacks:\n#   - EarlyStopping          (patience=10, restore best weights)\n#   - ReduceLROnPlateau      (factor=0.5, patience=5)\n#   - ModelCheckpoint        (saves best val_accuracy model)\n#   - Custom LR logger\n# Model saved as: ./models/model_{ASSET}_{timestamp}.keras\n\nimport pickle, joblib\n\nTRAINED_MODELS: dict[str, keras.Model]  = {}\nHISTORIES:      dict[str, dict]         = {}\n\n\ndef get_callbacks(asset: str, model_dir: str) -> list:\n    ts = datetime.now().strftime(\"%Y%m%d_%H%M\")\n    ckpt_path = os.path.join(model_dir, f\"model_{asset}_{ts}.keras\")\n\n    return [\n        callbacks.EarlyStopping(\n            monitor=\"val_accuracy\",\n            patience=10,\n            restore_best_weights=True,\n            verbose=1,\n        ),\n        callbacks.ReduceLROnPlateau(\n            monitor=\"val_loss\",\n            factor=0.5,\n            patience=5,\n            min_lr=1e-6,\n            verbose=1,\n        ),\n        callbacks.ModelCheckpoint(\n            filepath=ckpt_path,\n            monitor=\"val_accuracy\",\n            save_best_only=True,\n            verbose=1,\n        ),\n    ], ckpt_path\n\n\ndef compute_class_weights(y: np.ndarray) -> dict:\n    \"\"\"Inverse-frequency class weights to handle label imbalance.\"\"\"\n    from sklearn.utils.class_weight import compute_class_weight\n    classes = np.unique(y)\n    weights = compute_class_weight(\"balanced\", classes=classes, y=y)\n    return dict(zip(classes.tolist(), weights.tolist()))\n\n\nfor asset in CONFIG[\"assets\"]:\n    print(f\"\\n{'='*60}\")\n    print(f\" Training: {asset}\")\n    print(f\"{'='*60}\")\n\n    ds = DATASETS[asset]\n    cbs, ckpt_path = get_callbacks(asset, CONFIG[\"model_dir\"])\n    class_wts = compute_class_weights(ds[\"y_train\"])\n    print(f\"  Class weights: {class_wts}\")\n\n    model = build_model(\n        window_size   = CONFIG[\"window_size\"],\n        n_features    = ds[\"n_features\"],\n        lstm_units    = CONFIG[\"lstm_units\"],\n        dropout       = CONFIG[\"dropout\"],\n        learning_rate = CONFIG[\"learning_rate\"],\n    )\n\n    # Recompile with RL-weighted loss\n    model.compile(\n        optimizer=keras.optimizers.Adam(CONFIG[\"learning_rate\"]),\n        loss=rl_weighted_loss(CONFIG[\"rl_penalty_multiplier\"]),\n        metrics=[\"accuracy\"]\n    )\n\n    history = model.fit(\n        ds[\"X_train\"], ds[\"y_train\"],\n        validation_data=(ds[\"X_val\"], ds[\"y_val\"]),\n        epochs=CONFIG[\"epochs\"],\n        batch_size=CONFIG[\"batch_size\"],\n        class_weight=class_wts,\n        callbacks=cbs,\n        verbose=1,\n    )\n\n    T